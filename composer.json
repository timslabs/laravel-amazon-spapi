{
    "name": "tims/laravel-amazon-spapi",
    "description": "Laravel integration for Amazon's official Selling Partner API PHP SDK",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "amazon",
        "sp-api",
        "selling-partner-api",
        "ecommerce",
        "sdk"
    ],
    "authors": [
        {
            "name": "TIMS",
            "homepage": "https://github.com/timslabs"
        }
    ],
    "require": {
        "php": "^8.3",
        "amzn-spapi/sdk": "^1.0",
        "guzzlehttp/guzzle": "^7.9",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "illuminate/bus": "Required to dispatch report/feed queue jobs.",
        "mockery/mockery": "Required to use Tims\\AmazonSpApi\\Testing\\SpApiFake."
    },
    "autoload": {
        "psr-4": {
            "Tims\\AmazonSpApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tims\\AmazonSpApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "vendor/bin/pint --test",
        "lint:fix": "vendor/bin/pint",
        "test": "vendor/bin/phpunit --configuration phpunit.xml"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tims\\AmazonSpApi\\AmazonSpApiServiceProvider"
            ],
            "aliases": {
                "AmazonSpApi": "Tims\\AmazonSpApi\\Facades\\AmazonSpApi"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
